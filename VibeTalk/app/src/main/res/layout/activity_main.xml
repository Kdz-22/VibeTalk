<?xml version="1.0" encoding="utf-8"?>
<!-- activity_main.xml -->
<!--
    FLEXBOX aqui: o campo de input usa FlexboxLayout para alinhar
    o EditText e o botão Enviar lado a lado, com o EditText crescendo
    (flexGrow="1") e o botão mantendo tamanho fixo.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Barra do topo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#3F51B5"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬 VibeTalk"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Lista de mensagens -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp" />

    <!-- Área de input — usando FlexboxLayout! -->
    <!--
        FlexDirection.ROW (padrão): itens em linha
        AlignItems.CENTER: centraliza verticalmente
        O EditText usa layout_flexGrow="1" para ocupar o espaço restante
    -->
    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/inputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:padding="8dp"
        app:flexDirection="row"
        app:alignItems="center"
        app:flexWrap="nowrap">

        <EditText
            android:id="@+id/editTextMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Digite uma mensagem..."
            android:background="@drawable/bg_input"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textSize="15sp"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"
            app:layout_flexGrow="1" />

        <!-- Espaço entre input e botão -->
        <Space
            android:layout_width="8dp"
            android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_send_button"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Enviar mensagem"
            app:tint="#FFFFFF" />

    </com.google.android.flexbox.FlexboxLayout>

</LinearLayout>